{
  "name": "watsonhaw/lychee-worker",
  "type": "library",
  "description": "Rust-powered high-performance runtime — prefork HTTP/WebSocket server with hot-reload",
  "license": "MIT",
  "keywords": [
    "thinkphp",
    "thinkphp8",
    "worker",
    "websocket",
    "http-server",
    "rust",
    "php-extension",
    "php-ext",
    "ext-php-rs"
  ],
  "authors": [
    {
      "name": "watsonhaw",
      "email": "348748267@qq.com"
    }
  ],
  "require": {
    "php": ">=8.3,<8.4"
  },
  "require-dev": {
    "topthink/framework": "^8.0",
    "phpunit/phpunit": "^10.0",
    "guzzlehttp/guzzle": "^7.0",
    "symfony/process": "^6.0|^7.0",
    "ratchet/pawl": "^0.4.0",
    "react/event-loop": "^1.0",
    "watsonhaw/think-queue": "^1.0",
    "phpstan/phpstan": "^2.2",
    "friendsofphp/php-cs-fixer": "^3.95"
  },
  "autoload": {
    "psr-4": {
      "lychee\\worker\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "lychee\\worker\\tests\\": "tests"
    }
  },
  "extra": {
    "think": {
      "services": [
        "lychee\\worker\\Service"
      ],
      "config": {
        "worker": "src/config/worker.php"
      }
    }
  },
  "scripts": {
    "build": "cargo build --release",
    "install-ext": "bash scripts/install.sh",
    "test": [
      "@test-php",
      "@test-rust"
    ],
    "test-php": "phpunit",
    "test-rust": "cargo test --release",
    "analyze": [
      "@analyze-php",
      "@analyze-rust"
    ],
    "analyze-php": "phpstan --no-progress --memory-limit=1G",
    "analyze-rust": "cargo clippy --all-targets -- -D warnings",
    "fix-style": [
      "@fix-style-php",
      "@fix-style-rust"
    ],
    "fix-style-php": "php-cs-fixer fix",
    "fix-style-rust": "cargo fmt",
    "check-style": [
      "@check-style-php",
      "@check-style-rust"
    ],
    "check-style-php": "php-cs-fixer fix --dry-run",
    "check-style-rust": "cargo fmt -- --check"
  }
}