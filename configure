#!/usr/bin/env bash
# PIE adapter for lychee_worker — turns the standard autoconf-style
# `./configure && make && make install` flow into a cargo build.
#
# PIE (PHP Installer for Extensions) expects the classic php extension
# build pipeline. Since lychee_worker is written in Rust (ext-php-rs),
# we translate that here: `./configure` checks the toolchain and emits
# a Makefile; `make` runs `cargo build --release`; `make install` calls
# `scripts/install.sh` to copy the shared library and enable it in php.ini.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --- parse arguments ---------------------------------------------------------
ENABLE_LYCHEE_WORKER=1
for arg in "$@"; do
    case "${arg}" in
        --enable-lychee-worker|--enable-lychee-worker=yes) ENABLE_LYCHEE_WORKER=1 ;;
        --disable-lychee-worker|--enable-lychee-worker=no) ENABLE_LYCHEE_WORKER=0 ;;
        --with-php-config=*) ;;
        --prefix=*) ;;
        --enable-debug) ;;
        -h|--help)
            echo "Usage: $0 [--enable-lychee-worker|--disable-lychee-worker]"
            exit 0
            ;;
        *) ;;
    esac
done

if [ "${ENABLE_LYCHEE_WORKER}" -eq 0 ]; then
    echo "[configure] lychee_worker disabled via --disable-lychee-worker — emitting a no-op Makefile."
    cat > "${SCRIPT_DIR}/Makefile" <<'EOF'
.PHONY: all install clean
all:
	@echo "lychee_worker disabled; nothing to build."
install: all
	@echo "lychee_worker disabled; nothing to install."
clean:
	@echo "nothing to clean."
EOF
    exit 0
fi

# --- toolchain checks --------------------------------------------------------
echo "[configure] checking build toolchain for lychee_worker..."

if ! command -v cargo >/dev/null 2>&1; then
    echo "[configure] error: 'cargo' not found in PATH." >&2
    echo "[configure]        install Rust toolchain first: https://rustup.rs/" >&2
    exit 1
fi
echo "[configure]   cargo ... $(cargo --version)"

if ! command -v php-config >/dev/null 2>&1; then
    echo "[configure] error: 'php-config' not found in PATH." >&2
    echo "[configure]        install php-dev / php-devel for your PHP 8.3 package." >&2
    exit 1
fi
PHP_VERSION_FULL="$(php-config --version 2>/dev/null || true)"
PHP_MAJOR_MINOR="$(echo "${PHP_VERSION_FULL}" | cut -d. -f1,2)"
echo "[configure]   php-config ... ${PHP_VERSION_FULL}"

if [ "${PHP_MAJOR_MINOR}" != "8.3" ]; then
    echo "[configure] error: lychee_worker requires PHP 8.3, but php-config reports ${PHP_VERSION_FULL}." >&2
    exit 1
fi

# --- emit Makefile -----------------------------------------------------------
echo "[configure] generating Makefile at ${SCRIPT_DIR}/Makefile"

cat > "${SCRIPT_DIR}/Makefile" <<'EOF'
# Auto-generated by `./configure`.
# Delegates the standard PIE build targets to cargo + scripts/install.sh.
SHELL := /bin/bash
PROJECT_DIR := $(shell dirname $(realpath $(lastword $(MAKEFILE_LIST))))

.PHONY: all install clean

all:
	cd "$(PROJECT_DIR)" && cargo build --release

install: all
	cd "$(PROJECT_DIR)" && bash scripts/install.sh

clean:
	cd "$(PROJECT_DIR)" && cargo clean
EOF

echo "[configure] done. Run 'make' then 'make install' (or let PIE do that)."